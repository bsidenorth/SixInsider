# Supabase — use the service_role key here (server-side only, never expose to frontend)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Apify — token used to pull dataset items after a run-finished webhook fires
APIFY_TOKEN=your_apify_token

# Shared secret SixInsider expects in the `x-webhook-token` header on
# every inbound ingestion request, to reject forged calls.
INGEST_WEBHOOK_SECRET=choose_a_long_random_string

# Port the Express server listens on
PORT=8787
